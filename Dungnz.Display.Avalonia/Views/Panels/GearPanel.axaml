<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Dungnz.Display.Avalonia.ViewModels"
             xmlns:controls="using:Dungnz.Display.Avalonia.Controls"
             x:Class="Dungnz.Display.Avalonia.Views.Panels.GearPanel"
             x:DataType="vm:GearPanelViewModel">
  <controls:AnsiTextBlock FormattedText="{Binding GearText}" FontFamily="Consolas,Courier New,monospace" />
</UserControl>
