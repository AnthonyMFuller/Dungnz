<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Dungnz.Display.Avalonia.ViewModels"
             xmlns:controls="using:Dungnz.Display.Avalonia.Controls"
             x:Class="Dungnz.Display.Avalonia.Views.Panels.StatsPanel"
             x:DataType="vm:StatsPanelViewModel">
  <controls:AnsiTextBlock FormattedText="{Binding StatsText}" FontFamily="Consolas,Courier New,monospace" />
</UserControl>
