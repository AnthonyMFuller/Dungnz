<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Dungnz.Display.Avalonia.ViewModels"
             x:Class="Dungnz.Display.Avalonia.Views.Panels.LogPanel"
             x:DataType="vm:LogPanelViewModel">
  <ScrollViewer>
    <ItemsControl ItemsSource="{Binding LogLines}">
      <ItemsControl.ItemTemplate>
        <DataTemplate>
          <TextBlock Text="{Binding}" FontFamily="Consolas,Courier New,monospace" FontSize="10" />
        </DataTemplate>
      </ItemsControl.ItemTemplate>
    </ItemsControl>
  </ScrollViewer>
</UserControl>
